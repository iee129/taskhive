# Railway 환경변수 설정 예시
# Railway 대시보드 > Variables 탭에서 설정

SPRING_PROFILES_ACTIVE=prod

# Railway PostgreSQL 서비스 추가 시 자동 주입되는 값을 활용
SPRING_DATASOURCE_URL=jdbc:postgresql://<host>:<port>/<db>
SPRING_DATASOURCE_USERNAME=<username>
SPRING_DATASOURCE_PASSWORD=<password>

# Railway Redis 서비스 추가 시 설정
REDIS_HOST=<redis-host>
REDIS_PORT=6379

# 반드시 256비트 이상 무작위 값으로 교체
JWT_SECRET=change-me-in-production-use-256bit-random-string

# Vercel 배포 URL (예: https://taskhive.vercel.app)
CORS_ORIGINS=https://your-app.vercel.app

# Ollama 미사용 시 기본값 유지 (graceful degradation)
OLLAMA_URL=http://ollama:11434

# Sentry 에러 모니터링
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_ENVIRONMENT=production

# 이메일 발송 (Gmail App Password 사용)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@taskhive.app
